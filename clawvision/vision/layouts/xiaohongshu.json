{
  "name": "Xiaohongshu Web Note Detail Layout",
  "anchors": {
    "right_panel": "e.x > w * 0.45",
    "top_header": "e.x > w * 0.45 and e.y < h * 0.15",
    "bottom_footer": "e.x > w * 0.45 and e.y > h * 0.85"
  },
  "regions": {
    "media": {
      "left": "0",
      "top": "0",
      "right": "right_panel.min_x if right_panel.exists else w * 0.45",
      "bottom": "h"
    },
    "author": {
      "left": "right_panel.min_x if right_panel.exists else w * 0.45",
      "top": "0",
      "right": "w",
      "bottom": "top_header.max_y + 20 if top_header.exists else h * 0.15"
    },
    "bottom_bar": {
      "left": "right_panel.min_x if right_panel.exists else w * 0.45",
      "top": "bottom_footer.min_y - 20 if bottom_footer.exists else h * 0.85",
      "right": "w",
      "bottom": "h"
    },
    "scrollable": {
      "left": "right_panel.min_x if right_panel.exists else w * 0.45",
      "top": "author.bottom",
      "right": "w",
      "bottom": "bottom_bar.top"
    },
    "panel": {
      "left": "right_panel.min_x if right_panel.exists else w * 0.45",
      "top": "0",
      "right": "w",
      "bottom": "h"
    }
  }
}
