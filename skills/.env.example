# ============================================================
# 共享环境配置（FlowLens + Auto-Redbook-Skills 两个项目共用）
# 复制为 .env 并填入真实值
# cp .env.example .env
# ============================================================

# ── AI API 密钥（必填其中一个） ─────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# DashScope / 阿里云百炼（Qwen 模型）
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── FlowLens Agent 模型选择 ──────────────────────────────────
# 取消注释其中一行即可切换
# FLOWLENS_LLM_BACKEND=sonnet          # Anthropic Claude Sonnet（默认）
# FLOWLENS_LLM_BACKEND=openai          # OpenAI / DashScope Qwen
FLOWLENS_LLM_BACKEND=openai
FLOWLENS_OPENAI_MODEL=qwen-vl-max-2025-08-13

# ── 项目路径（新机器克隆时如果路径不同，在此修改） ──────────
# 默认值：~/小红书检索
# FLOWLENS_PROJECT_ROOT=/Users/yourname/小红书检索

# ── 小红书 Cookie（浏览器登录后从 DevTools Network 面板复制） ─
XHS_COOKIE=

# ── XHS 抗风控调优（保持默认值即可，有需要再调） ────────────
XHS_SEARCH_NAV_TIMEOUT_MS=18000
XHS_SEARCH_RESPONSE_TIMEOUT_MS=5500
XHS_SEARCH_OPEN_RETRIES=2
XHS_LIST_STAGNATION_ROUNDS=3
XHS_LIST_ROUND_DELAY_MIN_MS=220
XHS_LIST_ROUND_DELAY_MAX_MS=520
XHS_DETAIL_OPEN_TIMEOUT_MS=7000
XHS_NAV_TIMEOUT_MS=9000
XHS_CLICK_TIMEOUT_MS=4500
XHS_CARD_READY_TIMEOUT_MS=1200
XHS_AUTHOR_NOTE_DELAY_MIN_MS=350
XHS_AUTHOR_NOTE_DELAY_MAX_MS=700
XHS_CAPTCHA_PROBE_LIMIT=20
XHS_EXPLORE_TIMEOUT_SEC=1740
XHS_EXPLORE_PER_AUTHOR_NOTES=3
XHS_EXPLORE_HTTP_LOG=1

# ── Observer 背景截图（可选，macOS 专属） ───────────────────
# FLOWLENS_OBSERVER_ROOT=
# FLOWLENS_OBSERVER_CHECK_INTERVAL=5
# FLOWLENS_OBSERVER_VISION_ENABLED=false

# ── 本地 LLM（可选，需要 Apple Silicon + MLX） ──────────────
# FLOWLENS_WHISPER_CLI=
# FLOWLENS_WHISPER_MODELS_DIR=
