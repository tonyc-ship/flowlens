{
  "manifest_version": 3,
  "name": "XHS Research Agent",
  "version": "0.2.0",
  "description": "Chrome Extension + External Agent for XHS research",
  "permissions": ["activeTab", "tabs", "scripting", "storage", "alarms", "debugger"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.xiaohongshu.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
