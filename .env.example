# Optional local overrides for ClawVision.
# The runtime also falls back to `~/.zshrc.pre-oh-my-zsh` / `~/.zshrc`
# for these keys when they are not set here.

ANTHROPIC_API_KEY=

# LLM backend: "sonnet" (default, Anthropic API) or "qwen-local" (Qwen3.5-9B MLX)
CLAWVISION_LLM_BACKEND=

CLAWVISION_WHISPER_CLI=
CLAWVISION_WHISPER_MODELS_DIR=
