# Optional local overrides for FlowLens.
# The runtime also falls back to `~/.zshrc.pre-oh-my-zsh` / `~/.zshrc`
# for these keys when they are not set here.

ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
OPENAI_API_KEY=
OPENAI_AUTH_TOKEN=

# Chinese hosted providers (all OpenAI-compatible under the hood).
# Moonshot / Kimi: https://platform.moonshot.cn/
MOONSHOT_API_KEY=
# Alibaba 通义千问 / DashScope: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# LLM backend: "sonnet"/"anthropic", "openai", "kimi", "qwen",
# or local MLX: "qwen-local" / "ui-tars-local".
FLOWLENS_LLM_BACKEND=
FLOWLENS_MODEL_PROVIDER=
FLOWLENS_AUTH_METHOD=
FLOWLENS_ANTHROPIC_MODEL=
FLOWLENS_OPENAI_MODEL=
FLOWLENS_KIMI_MODEL=
FLOWLENS_QWEN_MODEL=

FLOWLENS_WHISPER_CLI=
FLOWLENS_WHISPER_MODELS_DIR=

# Observer subsystem
FLOWLENS_APP_DATA_DIR=
FLOWLENS_OBSERVER_ROOT=
FLOWLENS_OBSERVER_CHECK_INTERVAL=
FLOWLENS_OBSERVER_FORCE_CAPTURE_INTERVAL=
FLOWLENS_OBSERVER_SCREENSHOT_STRATEGY=
FLOWLENS_OBSERVER_DIFF_THRESHOLD=
FLOWLENS_OBSERVER_VISION_ENABLED=
FLOWLENS_OBSERVER_VISION_MODEL=
