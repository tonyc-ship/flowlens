# Optional local overrides for Socai.
# The runtime also falls back to `~/.zshrc.pre-oh-my-zsh` / `~/.zshrc`
# for these keys when they are not set here.

ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
OPENAI_API_KEY=
OPENAI_AUTH_TOKEN=

# Chinese hosted providers (all OpenAI-compatible under the hood).
# Moonshot / Kimi: https://platform.moonshot.cn/
MOONSHOT_API_KEY=
# Alibaba 通义千问 / DashScope: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# LLM backend: "sonnet"/"anthropic", "openai", "kimi", "qwen",
# or local MLX: "qwen-local" / "ui-tars-local".
SOCAI_LLM_BACKEND=
SOCAI_MODEL_PROVIDER=
SOCAI_AUTH_METHOD=
SOCAI_ANTHROPIC_MODEL=
SOCAI_OPENAI_MODEL=
SOCAI_KIMI_MODEL=
SOCAI_QWEN_MODEL=

SOCAI_WHISPER_CLI=
SOCAI_WHISPER_MODELS_DIR=

# Observer subsystem
SOCAI_APP_DATA_DIR=
SOCAI_OBSERVER_ROOT=
SOCAI_OBSERVER_CHECK_INTERVAL=
SOCAI_OBSERVER_FORCE_CAPTURE_INTERVAL=
SOCAI_OBSERVER_SCREENSHOT_STRATEGY=
SOCAI_OBSERVER_DIFF_THRESHOLD=
SOCAI_OBSERVER_VISION_ENABLED=
SOCAI_OBSERVER_VISION_MODEL=
